using System;
using System.Collections.Generic;

class Pedido
{
    public decimal Monto { get; set; }
    public string Ciudad { get; set; }
    public string TipoCliente { get; set; }
    public int CantidadItems { get; set; }
}

class Program
{
    static List<Pedido> pedidos = new List<Pedido>();

    static void Main()
    {
        int opcion;

        do
        {
            Console.WriteLine("\n=== SISTEMA DE CLASIFICACIÓN DE PEDIDOS ===");
            Console.WriteLine("1. Registrar pedido");
            Console.WriteLine("2. Ver registro de pedidos");
            Console.WriteLine("0. Salir");
            Console.Write("Seleccione una opción: ");

            if (!int.TryParse(Console.ReadLine(), out opcion))
            {
                Console.WriteLine("Opción inválida.");
                continue;
            }

            switch (opcion)
            {
                case 1:
                    ProcesarPedido();
                    break;

                case 2:
                    MostrarRegistros();
                    break;

                case 0:
                    Console.WriteLine("Saliendo del sistema...");
                    break;

                default:
                    Console.WriteLine("Opción no válida.");
                    break;
            }

        } while (opcion != 0);
    }

    static void ProcesarPedido()
    {
        decimal montoPedido;
        int cantidadItems;
        string ciudadDestino;
        string tipoCliente;

        decimal costoEnvio = 0;
        string categoriaDespacho = "";

        while (true)
        {
            Console.Write("\nIngrese el monto del pedido: ");
            if (decimal.TryParse(Console.ReadLine(), out montoPedido) && montoPedido >= 0)
                break;

            Console.WriteLine("Monto inválido.");
        }

        Console.Write("Ingrese la ciudad destino: ");
        ciudadDestino = Console.ReadLine().ToLower();

        while (true)
        {
            Console.Write("Ingrese el tipo de cliente (nuevo/recurrente): ");
            tipoCliente = Console.ReadLine().ToLower();

            if (tipoCliente == "nuevo" || tipoCliente == "recurrente")
                break;

            Console.WriteLine("Tipo inválido.");
        }

        while (true)
        {
            Console.Write("Ingrese la cantidad de ítems: ");
            if (int.TryParse(Console.ReadLine(), out cantidadItems) && cantidadItems > 0)
                break;

            Console.WriteLine("Cantidad inválida.");
        }

        if (montoPedido >= 150000 && tipoCliente == "recurrente")
        {
            categoriaDespacho = "Envío Gratis";
            costoEnvio = 0;
        }
        else if (cantidadItems >= 5 || montoPedido >= 300000)
        {
            categoriaDespacho = "Envío Express";
            costoEnvio = 20000;
        }
        else
        {
            categoriaDespacho = "Envío Estándar";
            costoEnvio = 10000;
        }

        if (ciudadDestino == "exterior")
        {
            costoEnvio += 15000;
        }

        pedidos.Add(new Pedido
        {
            Monto = montoPedido,
            Ciudad = ciudadDestino,
            TipoCliente = tipoCliente,
            CantidadItems = cantidadItems
        });

        Console.WriteLine("\n=== RESULTADO ===");
        Console.WriteLine($"Categoría: {categoriaDespacho}");
        Console.WriteLine($"Costo envío: ${costoEnvio}");

        int opcionFinal;
        do
        {
            Console.WriteLine("\n1. Registrar otro");
            Console.WriteLine("2. Ver registros");
            Console.WriteLine("0. Menú principal");
            Console.Write("Opción: ");
        } while (!int.TryParse(Console.ReadLine(), out opcionFinal));

        if (opcionFinal == 1)
            ProcesarPedido();
        else if (opcionFinal == 2)
            MostrarRegistros();
    }

    static void MostrarRegistros()
    {
        Console.WriteLine("\n=== REGISTRO DE PEDIDOS ===");

        if (pedidos.Count == 0)
        {
            Console.WriteLine("No hay pedidos.");
            return;
        }

        decimal suma = 0;

        for (int i = 0; i < pedidos.Count; i++)
        {
            Console.WriteLine($"Pedido {i + 1}:");
            Console.WriteLine($"  Monto: ${pedidos[i].Monto}");
            Console.WriteLine($"  Ciudad: {pedidos[i].Ciudad}");
            Console.WriteLine($"  Tipo cliente: {pedidos[i].TipoCliente}");
            Console.WriteLine($"  Items: {pedidos[i].CantidadItems}");
            Console.WriteLine("-------------------------");

            suma += pedidos[i].Monto;
        }

        decimal promedio = suma / pedidos.Count;

        Console.WriteLine($"\nTotal pedidos: {pedidos.Count}");
        Console.WriteLine($"Promedio monto: ${promedio}");
    }
}
